{
  "name": "michu-stays",
  "version": "1.0.0",
  "description": "Michu Stays - Ethiopian Booking Platform",
  "main": "index.html",
  "scripts": {
    "prebuild": "node -e \"const fs=require('fs');const cp=require('child_process');['index.html','sw.js','manifest.json','firebase-messaging-sw.js','capacitor.config.json'].forEach(f=>{try{fs.copyFileSync(f,'www/'+f)}catch(e){}});['js','css','images'].forEach(d=>{cp.execSync('xcopy /s /y /i '+d+' www\\\\'+d,{stdio:'ignore'})})\"",
    "build": "npm run prebuild && npx cap sync",
    "open:android": "npx cap open android",
    "sync": "npm run prebuild && npx cap sync"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/app": "^6.0.3",
    "@capacitor/cli": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/device": "^6.0.0",
    "@capacitor/push-notifications": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0"
  }
}
